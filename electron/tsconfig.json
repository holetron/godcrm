{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "../dist-electron",
    "rootDir": "..",
    "sourceMap": true,
    "declaration": false
  },
  "include": ["**/*.ts", "../src/shared/types/electron.types.ts"],
  "exclude": ["**/*.test.ts"]
}
