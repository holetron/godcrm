# ============================================================
# GOD CRM BOT v3.0 — Multi-User Configuration
# ============================================================
# Скопируй как .env:  cp .env.example .env
# ============================================================

# === TELEGRAM (ОБЯЗАТЕЛЬНО) ===
# Получи токен: @BotFather → /newbot → скопируй токен
TELEGRAM_BOT_TOKEN=ВСТАВЬ_СЮДА_СВОЙ_ТОКЕН

# Имя бота (для отображения)
BOT_NAME=GOD CRM Bot

# === АДМИН БОТА (ОБЯЗАТЕЛЬНО) ===
# Telegram User ID владельца бота
# Узнать свой ID: напиши боту /whoami
ADMIN_TELEGRAM_ID=ВСТАВЬ_СВОЙ_TELEGRAM_ID

# === CRM ПОДКЛЮЧЕНИЕ ===
# URL сервера CRM
CRM_API_URL=https://crm.hltrn.cc

# JWT Secret для авторизации (попроси у админа)
CRM_JWT_SECRET=ПОПРОСИ_У_АДМИНА

# === CRM ДЕФОЛТНОГО ЮЗЕРА (для админа) ===
# CRM User ID админа
CRM_USER_ID=1

# CRM Email админа
CRM_USER_EMAIL=admin@godcrm.local

# === ТАБЛИЦЫ CRM (по умолчанию для всех юзеров) ===
# Можно менять индивидуально через /settable
SPRINT_TABLE_ID=2649
HEALTH_TABLE_ID=2643
