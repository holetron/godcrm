# =============================================
# Trainer Bot — Environment Configuration
# Copy to .env and fill in actual values
# NEVER commit .env to git
# =============================================

# --- Telegram ---
# Bot token from @BotFather
TRAINER_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram chat IDs of authorized trainers
# Example: 123456789,987654321
AUTHORIZED_TRAINER_IDS=

# --- Database (PostgreSQL) ---
# Connection to godcrm_prod
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=godcrm_prod
POSTGRES_USER=godcrm
POSTGRES_PASSWORD=your_postgres_password_here

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Model to use: claude-opus-4-6 or claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- CRM API (optional — for REST-based access) ---
# If set, uses REST API instead of direct DB
# Leave blank to use direct DB connection (recommended)
CRM_API_BASE_URL=http://localhost:5000
CRM_API_KEY=

# --- Table IDs (do NOT change unless tables are recreated) ---
EXERCISES_TABLE_ID=2964
MUSCLES_TABLE_ID=2657
TRAINING_SESSIONS_TABLE_ID=3477

# --- Bot settings ---
NODE_ENV=development
LOG_LEVEL=info
# Max plan text length accepted by bot (chars)
MAX_PLAN_LENGTH=10000
