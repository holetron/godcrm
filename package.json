{
  "name": "business-crm",
  "version": "1.2.0",
  "description": "GOD CRM - Universal Workspace Management System (Clean Architecture)",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node backend/server.js",
    "client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:desktop:renderer": "vite build --config vite.config.desktop.ts",
    "build:desktop:main": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\"",
    "build:desktop": "npm run build:desktop:renderer && npm run build:desktop:main",
    "electron:dev": "npm run build:desktop && electron .",
    "dist:linux:appimage": "npm run build:desktop && electron-builder --linux AppImage",
    "dist:win": "npm run build:desktop && electron-builder --win --x64",
    "dist:mac": "npm run build:desktop && electron-builder --mac --universal",
    "dist:all": "npm run build:desktop && electron-builder -lwm",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "test:ui": "NODE_ENV=test vitest --ui",
    "test:backend": "NODE_ENV=test vitest run backend/",
    "test:frontend": "NODE_ENV=test vitest run src/",
    "test:postgres": "TEST_POSTGRES=true vitest run backend/database/__tests__/connection-postgres.test.js",
    "smoke:adr-0042": "node scripts/smoke-adr0151.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:tables": "playwright test tables.spec.ts",
    "test:e2e:widgets": "playwright test widgets.spec.ts",
    "test:e2e:spaces": "playwright test spaces.spec.ts",
    "test:e2e:integration": "playwright test integration.spec.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:backend": "eslint backend/ --ext .js",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "docs:generate": "node backend/scripts/generate-openapi.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
